# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000

# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Wati (WhatsApp)
WATI_API_KEY=your_wati_api_key
WATI_WEBHOOK_TOKEN=your_wati_webhook_token

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PRICE_BASIC=your_stripe_price_id_basic
STRIPE_PRICE_PRO=your_stripe_price_id_pro
STRIPE_PRICE_PREMIUM=your_stripe_price_id_premium

# JWT
JWT_SECRET=your_jwt_secret_random_string

# Google Calendar
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
